{
  "name": "chainlens",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --filter @chainlens/backend --filter @chainlens/frontend dev",
    "build": "pnpm --filter @chainlens/shared build && pnpm --filter @chainlens/backend build && pnpm --filter @chainlens/frontend build",
    "test": "pnpm -r test",
    "contracts:compile": "pnpm --filter @chainlens/contracts compile",
    "contracts:test": "pnpm --filter @chainlens/contracts test",
    "db:migrate": "pnpm --filter @chainlens/backend db:migrate",
    "db:studio": "pnpm --filter @chainlens/backend db:studio",
    "clean": "pnpm -r exec rm -rf dist node_modules .next"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "prettier": "^3.4.0"
  }
}
