# ── Backend ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/monapi
PORT=3001
PRIVATE_KEY=0x_YOUR_GATEWAY_PRIVATE_KEY
CONTRACT_ADDRESS=0x_DEPLOYED_CONTRACT_ADDRESS
RPC_URL=https://sepolia.base.org
CORS_ORIGIN=http://localhost:3000
ADMIN_ADDRESSES=0xADDRESS1,0xADDRESS2
JWT_SECRET=change-this-to-a-random-32-char-minimum-secret

# ── Frontend (baked in at build time) ──────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001/api
NEXT_PUBLIC_CONTRACT_ADDRESS=0x_DEPLOYED_CONTRACT_ADDRESS
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID
NEXT_PUBLIC_ADMIN_ADDRESSES=0xADDRESS1,0xADDRESS2
NEXT_PUBLIC_CHAIN_ID=84532

# ── ChainLens MCP tool (safe defaults; no secrets) ─────
CHAIN_LENS_API_URL=http://localhost:3001/api
CHAIN_LENS_CHAIN_ID=84532
CHAIN_LENS_RPC_URL=https://sepolia.base.org

# Optional signing modes. Leave unset for read/prep-only MCP usage.
# CHAIN_LENS_WALLET_PRIVATE_KEY=0x_YOUR_TESTNET_THROWAWAY_PRIVATE_KEY
# CHAIN_LENS_SIGN_SOCKET=/home/you/.chain-lens/sign.sock

# Smart account registration mode.
# CHAIN_LENS_SIGNING_PROVIDER=smart_account
# CHAIN_LENS_SMART_ACCOUNT_ADDRESS=0x_YOUR_SMART_ACCOUNT_ADDRESS
# CHAIN_LENS_SESSION_KEY_PRIVATE_KEY=0x_YOUR_TESTNET_SESSION_KEY
# CHAIN_LENS_PAYOUT_ALLOWLIST=0xPAYOUT_ADDRESS_1,0xPAYOUT_ADDRESS_2

# WAIAAS registration mode is adapter-ready only. The registration tool stays
# hidden until a real provider SDK client is wired into the MCP server.
# CHAIN_LENS_SIGNING_PROVIDER=waiaas
# CHAIN_LENS_WAIAAS_API_URL=https://api.example-waiaas.invalid/v1
# CHAIN_LENS_WAIAAS_API_KEY=YOUR_WAIAAS_API_KEY
# CHAIN_LENS_WAIAAS_WALLET_ID=YOUR_WAIAAS_WALLET_ID
