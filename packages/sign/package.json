{
  "name": "@chain-lens/sign",
  "version": "0.0.3",
  "description": "Encrypted wallet keystore CLI + signing daemon for ChainLens. Spending limits and per-tx approval prompts; the safer alternative to WALLET_PRIVATE_KEY env.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chain-Lens/ChainLens.git",
    "directory": "packages/sign"
  },
  "keywords": [
    "chain-lens",
    "cli",
    "keystore",
    "ethereum",
    "wallet",
    "sign",
    "web3"
  ],
  "type": "module",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "chain-lens-sign": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test": "tsx --test 'src/**/*.test.ts'",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
