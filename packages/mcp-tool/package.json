{
  "name": "@chain-lens/mcp-tool",
  "version": "0.0.13",
  "description": "ChainLens MCP tool — discover sellers, request data, check job status from Claude Desktop and other MCP clients.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chain-Lens/ChainLens.git",
    "directory": "packages/mcp-tool"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "chain-lens",
    "base",
    "web3",
    "agents"
  ],
  "type": "module",
  "main": "dist/index.js",
