generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ApiStatus {
  PENDING
  APPROVED
  REJECTED
  REVOKED
}

enum PaymentStatus {
  PENDING
  PAID
  EXECUTING
  COMPLETED
  REFUNDED
  FAILED
}

enum JobStatus {
  PENDING
  PAID
  COMPLETED
  REFUNDED
  FAILED
}

model Job {
  id               Int       @id @default(autoincrement())
  // On-chain jobId emitted by ApiMarketEscrowV2.JobCreated. Not unique on
  // its own — the Phase-3.5 escrow redeploy restarted jobId counters
  // from 0 and collided with leftover rows from the old escrow, which
  // stalled the listener on "unique constraint failed." The compound
  // unique below scopes jobIds to the specific escrow that emitted them.
  onchainJobId     BigInt
  // Address of the escrow that emitted JobCreated. Empty string means
  // the row predates the v0.1.1 migration; new writes from the listener
  // always populate this.
  escrowAddress    String    @default("")
  buyer            String
  seller           String
  apiId            BigInt
  taskType         String?
  amount           Decimal   @db.Decimal(18, 6)
  inputs           Json?
  inputsHash       String
  response         Json?
  responseHash     String?
  evidenceURI      String?
  status           JobStatus
  errorReason      String?
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@unique([escrowAddress, onchainJobId])
  @@index([onchainJobId])
  @@index([buyer])
  @@index([seller])
  @@index([taskType])
  @@index([status])
}

model SellerProfile {
  id              Int      @id @default(autoincrement())
  sellerAddress   String   @unique
  name            String
  endpointUrl     String
  capabilities    Json
  pricePerCall    Decimal  @db.Decimal(18, 6)
  metadataURI     String?
  status          String
  testResult      Json?
  jobsCompleted   Int      @default(0)
  jobsFailed      Int      @default(0)
  totalEarnings   Decimal  @default(0) @db.Decimal(18, 6)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model ApiTestResult {
  id              Int      @id @default(autoincrement())
  sellerAddress   String
  capability      String
  testInput       Json
  testOutput      Json?
  responseTimeMs  Int?
  schemaValid     Boolean?
  injectionFree   Boolean?
  statusCode      Int?
  errorMessage    String?
  testedAt        DateTime @default(now())

  @@index([sellerAddress])
}

model ApiListing {
  id             String    @id @default(uuid())
  // null / "" = legacy v2 (ApiMarketEscrow); "V3" = ChainLensMarket.
  // Needed because v2 and v3 both restart onChainId at 0, so the bare
  // @unique onChainId used to be a collision risk once v3 listings started
  // flowing in via the market listener.
  contractVersion String?
  onChainId       Int?
  name           String
  description    String
  endpoint       String
  price          String
  category       String    @default("general")
  sellerAddress  String
  exampleRequest Json?
  exampleResponse Json?
  status         ApiStatus @default(PENDING)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  payments     PaymentRequest[]
  adminActions AdminAction[]

  @@unique([contractVersion, onChainId])
  @@index([status])
  @@index([sellerAddress])
  @@index([contractVersion, status])
}

model PaymentRequest {
  id               String        @id @default(uuid())
  apiId            String
  buyer            String
  seller           String
  amount           String
  onChainPaymentId Int?          @unique
  status           PaymentStatus @default(PENDING)
  txHash           String?
  completionTxHash String?
  result           Json?
  errorMessage     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  api ApiListing @relation(fields: [apiId], references: [id])

  @@index([status])
  @@index([buyer])
  @@index([txHash])
}

model AdminAction {
  id           String   @id @default(uuid())
  apiId        String
  action       String
  adminAddress String
  reason       String?
  createdAt    DateTime @default(now())

  api ApiListing @relation(fields: [apiId], references: [id])
}

// Per-call observability row for v3 ChainLensMarket listings. One row per
// POST /api/market/call/:id invocation that reached the listing-resolution
// stage (pre-parse errors like malformed listingId are skipped — they carry
// no listing signal). Feeds per-listing stats + ranking in Phase 2b.
model CallLog {
  id            String   @id @default(cuid())
  listingId     Int
  buyer         String
  success       Boolean
  sellerStatus  Int?
  latencyMs     Int
  amount        String
  jobRef        String
  settleTxHash  String?
  errorReason   String?
  createdAt     DateTime @default(now())

  @@index([listingId, createdAt])
  @@index([listingId, success])
  @@index([buyer])
}
