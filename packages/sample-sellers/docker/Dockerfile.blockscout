# Build from repo root: `docker build -f packages/sample-sellers/docker/Dockerfile.blockscout -t chainlens/blockscout-wrapper .`
FROM node:20-alpine AS build
WORKDIR /repo
RUN corepack enable
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json tsconfig.base.json ./
COPY packages/sample-sellers/package.json packages/sample-sellers/tsconfig.json packages/sample-sellers/
COPY packages/sample-sellers/src packages/sample-sellers/src
RUN pnpm install --filter @chainlens/sample-sellers... --frozen-lockfile
RUN pnpm --filter @chainlens/sample-sellers build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=8081
RUN corepack enable
COPY --from=build /repo/packages/sample-sellers/package.json ./package.json
COPY --from=build /repo/packages/sample-sellers/dist ./dist
RUN pnpm install --prod --ignore-scripts
EXPOSE 8081
CMD ["node", "dist/blockscout/index.js"]
